# Horizon Protocol - Environment Configuration
# Copy this file to .env.devnet, .env.sepolia, or .env.mainnet

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
STARKNET_NETWORK=devnet  # devnet | sepolia | mainnet
STARKNET_RPC_URL=http://localhost:5050

# =============================================================================
# DEPLOYER ACCOUNT
# =============================================================================
# For devnet, use prefunded accounts (no keystore needed)
# For Sepolia/Mainnet, use starkli account file

DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# Treasury address for protocol fees and post-expiry yield
# If empty, deployment scripts default to DEPLOYER_ADDRESS
TREASURY_ADDRESS=

# Alternatively, use keystore (for Sepolia/Mainnet)
# DEPLOYER_KEYSTORE=~/.starkli-wallets/deployer/keystore.json
# DEPLOYER_ACCOUNT=~/.starkli-wallets/deployer/account.json

# =============================================================================
# CLASS HASHES (populated after declaration)
# =============================================================================
MOCK_YIELD_TOKEN_CLASS_HASH=
SY_CLASS_HASH=
PT_CLASS_HASH=
YT_CLASS_HASH=
MARKET_CLASS_HASH=
FACTORY_CLASS_HASH=
MARKET_FACTORY_CLASS_HASH=
ROUTER_CLASS_HASH=

# =============================================================================
# DEPLOYED CONTRACT ADDRESSES (populated after deployment)
# =============================================================================
MOCK_YIELD_TOKEN_ADDRESS=
SY_ADDRESS=
FACTORY_ADDRESS=
MARKET_FACTORY_ADDRESS=
ROUTER_ADDRESS=

# PT/YT pairs created via Factory
PT_ADDRESS=
YT_ADDRESS=

# Markets created via MarketFactory
MARKET_ADDRESS=

# =============================================================================
# DEPLOYMENT PARAMETERS
# =============================================================================
# Expiry timestamp for PT/YT (Unix timestamp)
# Example: 1735689600 = Jan 1, 2025 00:00:00 UTC
EXPIRY_TIMESTAMP=

# Market parameters (in WAD - 18 decimals)
# scalar_root: Controls rate sensitivity, must be in [1 WAD, 1000 WAD] (recommended: 5 WAD)
MARKET_SCALAR_ROOT=5000000000000000000

# initial_anchor: Starting ln(implied_rate) (recommended: 0.05 * 10^18 = 5%)
MARKET_INITIAL_ANCHOR=50000000000000000

# fee_rate: Swap fee (recommended: 0.003 * 10^18 = 0.3%)
MARKET_FEE_RATE=3000000000000000

# =============================================================================
# LIQUIDITY SEEDING
# =============================================================================
# Enable automatic liquidity seeding after market creation
SEED_LIQUIDITY=true

# Amount of liquidity to seed per market (in WAD - 18 decimals)
# Recommended: 1,000,000 tokens = 1000000 * 10^18
SEED_LIQUIDITY_AMOUNT=1000000000000000000000000
