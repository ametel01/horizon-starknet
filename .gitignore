# =============================================================================
# Yield Tokenization Protocol - Monorepo .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment files (contain secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.katana
.env.sepolia
.env.mainnet

# Keep examples
!.env.example

# -----------------------------------------------------------------------------
# Cairo / Starknet
# -----------------------------------------------------------------------------
target/
contracts/target/
.snfoundry_cache/
snfoundry_trace/
coverage/
profile/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
packages/*/node_modules/
.next/
out/
dist/
build/
.turbo/
.vercel/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.cache/
