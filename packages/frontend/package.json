{
  "name": "horizon-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "browserslist": [
    "chrome >= 92",
    "edge >= 92",
    "firefox >= 90",
    "safari >= 15.4"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:fork": "NEXT_PUBLIC_NETWORK=fork next dev",
    "dev:turbo": "next dev --turbo",
    "dev:fork:turbo": "NEXT_PUBLIC_NETWORK=fork next dev --turbo",
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "check": "bun run typecheck && biome check src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf .next node_modules/.cache",
    "codegen": "bun run scripts/generate-types.ts && bun run format",
    "find-deadcode": "ts-prune",
    "commit:check": "rm -rf node_modules && bun install && (cd ../.. && make build) && bun run codegen && bun run build && bun run format && bun run check && bun run test && bun run test:e2e"
  },
  "dependencies": {
    "@avnu/avnu-sdk": "^4.0.1",
    "@base-ui/react": "^1.4.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.49.0",
    "@starknet-io/get-starknet": "^4.0.8",
    "@tanstack/react-query": "^5.99.2",
    "@types/katex": "^0.16.8",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bignumber.js": "^11.0.0",
    "cairo-fp": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "starknet": "^9.4.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "abi-wan-kanabi": "^2.2.4",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "shadcn": "^4.4.0",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3"
  }
}
