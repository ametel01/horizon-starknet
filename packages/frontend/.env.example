# Network configuration
NEXT_PUBLIC_NETWORK=sepolia

# RPC endpoints
NEXT_PUBLIC_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7

# Contract addresses (update after deployment)
NEXT_PUBLIC_ROUTER_ADDRESS=0x...
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=0x...

# Indexer Database (server-side only, used by API routes)
# For Railway: use DATABASE_PUBLIC_URL for external access
DATABASE_URL=postgresql://user:password@host:5432/database
