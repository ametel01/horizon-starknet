# Network configuration
NEXT_PUBLIC_NETWORK=mainnet

# Starknet RPC URL (server-side only, proxied to client via /api/rpc)
RPC_URL=https://starknet-mainnet.public.blastapi.io/rpc/v0_7

# Indexer Database (server-side only)
DATABASE_URL=postgresql://user:password@host:5432/database

# Sentry configuration (server-side only)
SENTRY_DSN=https://examplekey@o0.ingest.sentry.io/0
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
