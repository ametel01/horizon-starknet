{
  "name": "@horizon/indexer",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "cd ../../contracts && scarb clean && scarb build && cd ../packages/indexer && bun run scripts/generate-events-abi.ts",
    "dev": "bunx apibara dev",
    "dev:mainnet": "bunx apibara dev --preset mainnet",
    "dev:sepolia": "bunx apibara dev --preset sepolia",
    "dev:devnet": "bunx apibara dev --preset devnet",
    "build": "bun build ./src/indexers/*.ts --outdir ./dist --target bun --external @electric-sql/pglite",
    "build:apibara": "bunx apibara build",
    "prepare": "bunx apibara build",
    "clean": "rm -rf dist .apibara",
    "format": "biome format src scripts tests --write",
    "format:check": "biome format src scripts tests",
    "lint": "biome lint src scripts tests",
    "lint:fix": "biome lint src scripts tests --write",
    "check": "bun run typecheck && biome check src scripts tests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:reset-checkpoints": "bun run scripts/reset-checkpoints.ts",
    "db:cleanup-triggers": "bun run scripts/cleanup-triggers.ts",
    "db:create-views": "bun run scripts/create-views.ts",
    "db:refresh-views": "bun run scripts/refresh-views.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "commit:check": "rm -rf node_modules && bun install && bun run codegen && bun run build && bun run format && bun run check && bun run test"
  },
  "dependencies": {
    "@apibara/indexer": "^2.1.0-beta.47",
    "@apibara/plugin-drizzle": "^2.1.0-beta.47",
    "@apibara/protocol": "^2.1.0-beta.47",
    "@apibara/starknet": "^2.1.0-beta.47",
    "apibara": "^2.1.0-beta.47",
    "drizzle-orm": "0.45.1",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "postgres": "latest",
    "starknet": "latest",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@electric-sql/pglite": "^0.3.14",
    "@types/bun": "latest",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3",
    "typescript": "latest",
    "vitest": "^4.0.16"
  }
}
