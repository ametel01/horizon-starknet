{
  "name": "@horizon/indexer",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "bun run scripts/generate-events-abi.ts",
    "dev": "bunx apibara dev",
    "dev:mainnet": "bunx apibara dev --preset mainnet",
    "dev:sepolia": "bunx apibara dev --preset sepolia",
    "dev:devnet": "bunx apibara dev --preset devnet",
    "build": "bun build ./src/indexers/*.ts --outdir ./dist --target bun --external @electric-sql/pglite",
    "build:apibara": "bunx apibara build",
    "prepare": "bunx apibara build",
    "clean": "rm -rf dist .apibara",
    "format": "prettier --write \"{src,scripts,tests}/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"{src,scripts,tests}/**/*.{ts,tsx,json,css,md}\"",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:reset-checkpoints": "bun run scripts/reset-checkpoints.ts",
    "db:cleanup-triggers": "bun run scripts/cleanup-triggers.ts",
    "db:create-views": "bun run scripts/create-views.ts",
    "db:refresh-views": "bun run scripts/refresh-views.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest"
  },
  "dependencies": {
    "@apibara/indexer": "^2.1.0-beta.47",
    "@apibara/plugin-drizzle": "^2.1.0-beta.47",
    "@apibara/protocol": "^2.1.0-beta.47",
    "@apibara/starknet": "^2.1.0-beta.47",
    "apibara": "^2.1.0-beta.47",
    "drizzle-orm": "0.45.1",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "postgres": "latest",
    "prettier": "latest",
    "starknet": "latest",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-promise": "^7.0.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^15.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "latest",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16"
  }
}
