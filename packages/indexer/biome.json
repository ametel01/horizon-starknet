{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/src/**/*.ts",
      "**/scripts/**/*.ts",
      "**/tests/**/*.ts",
      "**/*.config.ts",
      "**/*.config.mjs",
      "**/*.config.cjs",
      "**/*.config.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessTypeConstraint": "error",
        "useLiteralKeys": "warn",
        "noExcessiveCognitiveComplexity": "warn",
        "noUselessFragments": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useTemplate": "error",
        "useNodejsImportProtocol": "error",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "useArrayLiterals": "error",
        "useBlockStatements": "off",
        "noParameterAssign": "off",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "requireAscii": true,
            "filenameCases": ["kebab-case"]
          }
        },
        "useArrayLiterals": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {}
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": "error",
        "noDoubleEquals": "error",
        "noEmptyBlockStatements": "warn",
        "noAssignInExpressions": "error",
        "noConfusingVoidType": "error",
        "noDebugger": "error",
        "noVar": "error"
      },
      "security": {
        "noGlobalEval": "error"
      },
      "performance": {
        "noAccumulatingSpread": "warn",
        "noDelete": "warn"
      },
      "nursery": {}
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["**/src/indexers/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": ["**/scripts/**/*.ts", "**/apibara.config.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/vitest.config.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.config.ts",
        "**/*.config.mjs",
        "**/*.config.cjs",
        "**/*.config.js"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off",
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
