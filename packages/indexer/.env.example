# PostgreSQL connection
POSTGRES_CONNECTION_STRING="postgres://horizon:horizon@localhost:5432/horizon_indexer"

# DNA Server URL (your self-hosted DNA server)
DNA_STREAM_URL="http://localhost:7171"

# DNA Token (not required for local self-hosted DNA, but suppresses warning)
DNA_TOKEN="local"

# Starknet RPC URL for DNA server (used by docker-compose)
# For local devnet:
STARKNET_RPC_URL="http://host.docker.internal:5050"
# For Alchemy: STARKNET_RPC_URL="https://starknet-mainnet.g.alchemy.com/v2/YOUR_API_KEY"
# For Infura: STARKNET_RPC_URL="https://starknet-mainnet.infura.io/v3/YOUR_PROJECT_ID"

# Optional: Runtime config override
# APIBARA_RUNTIME_CONFIG='{"starknet": {"startingBlock": 800000}}'
