# Horizon Frontend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Network to connect to: mainnet | sepolia | devnet | fork
# - devnet: Local starknet-devnet-rs (default, runs on localhost:5050)
# - fork: Local fork of mainnet (runs on localhost:5050 with mainnet state)
# - sepolia: Starknet testnet
# - mainnet: Starknet mainnet
VITE_NETWORK=devnet

# =============================================================================
# RPC CONFIGURATION (Server-side only)
# =============================================================================

# Starknet RPC endpoint URL (required for mainnet/sepolia)
# This is kept server-side only to protect your API key.
# The frontend proxies requests through /api/rpc.
#
# For devnet/fork: Not required (uses http://localhost:5050)
# For mainnet/sepolia: Required - get an API key from:
#   - Alchemy: https://www.alchemy.com/starknet
#   - Infura: https://www.infura.io/
#
# Examples:
# RPC_URL=https://starknet-mainnet.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_API_KEY
# RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_API_KEY
# RPC_URL=https://starknet-mainnet.infura.io/v3/YOUR_PROJECT_ID
RPC_URL=
