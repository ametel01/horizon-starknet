{
  "name": "horizon-frontend-solid",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "dev:fork": "VITE_NETWORK=fork vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "check": "bun run typecheck && biome check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .vinxi .output node_modules/.cache",
    "codegen": "bun run scripts/generate-types.ts"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.9",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.1.0",
    "@starknet-io/get-starknet": "^4.0.8",
    "@tanstack/solid-query": "^5.90.16",
    "bignumber.js": "^9.3.1",
    "cairo-fp": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "solid-js": "^1.9.5",
    "solid-sonner": "^0.2.8",
    "starknet": "^9.2.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vinxi": "^0.5.3",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "abi-wan-kanabi": "^2.2.4",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
